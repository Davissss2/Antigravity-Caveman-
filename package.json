{
  "name": "antigravity-caveman",
  "displayName": "🦖 Antigravity Caveman",
  "description": "Toggle caveman token compression for Antigravity AI — adds a status bar menu to activate/deactivate directly in the IDE",
  "version": "1.6.0",
  "publisher": "Davissss2",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Davissss2/Antigravity-Caveman-.git"
  },
  "icon": "icon.png",
  "engines": {
    "vscode": "^1.60.0"
  },
  "categories": ["Other"],
  "keywords": ["caveman", "tokens", "compression", "antigravity", "ai"],
  "activationEvents": ["onStartupFinished"],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "caveman.menu",
        "title": "🦖 Caveman: Open Menu"
      },
      {
        "command": "caveman.activate",
        "title": "🦖 Caveman: Activate"
      },
      {
        "command": "caveman.deactivate",
        "title": "🛑 Caveman: Deactivate"
      },
      {
        "command": "caveman.compressActiveFile",
        "title": "🦖 Caveman: Compress Active File"
      },
      {
        "command": "caveman.generateCommit",
        "title": "🦖 Caveman: Generate Commit Message"
      },
      {
        "command": "caveman.codeReview",
        "title": "🦖 Caveman: Code Review"
      },
      {
        "command": "caveman.showStats",
        "title": "🦖 Caveman: Show Session Stats"
      }
    ]
  },
  "scripts": {
    "package": "vsce package --allow-missing-publisher-name"
  }
}
